# ----------------------------------------------------------------------------
# Private AI Platform — API configuration
# Copy to .env and adjust. All values have safe local defaults.
# ----------------------------------------------------------------------------

# Core
APP_ENV=development
SECRET_KEY=change-me-in-production-please-32-chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Database. Default = local SQLite file. For Postgres/pgvector use e.g.:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/privateai
DATABASE_URL=sqlite:///./privateai.db

# CORS (comma separated origins for the web portal)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Privacy Model Router -------------------------------------------------
# Routes are tried in order of the policy. The MOCK adapter always works with
# zero configuration so the platform runs end-to-end out of the box.

# Premium external model (OpenAI / Claude / Gemini compatible endpoint)
PREMIUM_ENABLED=false
PREMIUM_BASE_URL=https://api.openai.com/v1
PREMIUM_API_KEY=
PREMIUM_MODEL=gpt-4o-mini

# Cost-optimized open model (OpenRouter / managed open models)
OPEN_ENABLED=false
OPEN_BASE_URL=https://openrouter.ai/api/v1
OPEN_API_KEY=
OPEN_MODEL=meta-llama/llama-3.1-8b-instruct

# VPC / privately hosted OpenAI-compatible endpoint (vLLM / TGI)
VPC_ENABLED=false
VPC_BASE_URL=http://vllm:8000/v1
VPC_API_KEY=
VPC_MODEL=Qwen2.5-7B-Instruct

# Local / self-hosted (Ollama)
LOCAL_ENABLED=false
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1

# ---- Embeddings / RAG -----------------------------------------------------
# By default a deterministic local embedder is used (no external calls).
# Set EMBEDDINGS_PROVIDER=openai to use a real embeddings endpoint.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_DIM=384
